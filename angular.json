{
  "$schema": "./node_modules/@angular/cli/lib/config/schema.json",
  "version": 1,
  "cli": {
    "packageManager": "bun",
    "analytics": "67041da8-5eec-4fa8-9270-34cccb9fcfdd"
  },
  "newProjectRoot": "projects",
  "projects": {
    "aurea": {
      "projectType": "library",
      "root": "projects/aurea",
      "sourceRoot": "projects/aurea/src",
      "prefix": "au",
      "architect": {
        "build": {
          "builder": "@angular/build:ng-packagr",
          "configurations": {
            "production": {
              "tsConfig": "projects/aurea/tsconfig.lib.prod.json"
            },
            "development": {
              "tsConfig": "projects/aurea/tsconfig.lib.json"
            }
          },
          "defaultConfiguration": "production"
        },
        "test": {
          "builder": "@angular/build:unit-test",
          "options": {
            "tsConfig": "projects/aurea/tsconfig.spec.json"
          },
          "configurations": {
            "coverage": {
              "coverage": true,
              "coverageReporters": ["text", "text-summary", "html"],
              "coverageInclude": ["projects/aurea/src/lib/**/*.ts"],
              "coverageExclude": [
                "projects/aurea/src/lib/**/*.stories.ts",
                "projects/aurea/src/lib/**/*.docs-overview.ts"
              ],
              "coverageThresholds": {
                "statements": 100,
                "branches": 100,
                "functions": 100,
                "lines": 100
              }
            }
          }
        },
        "storybook": {
          "builder": "@storybook/angular:start-storybook",
          "options": {
            "configDir": "projects/aurea/.storybook",
            "browserTarget": "aurea:build",
            "compodoc": true,
            "compodocArgs": [
              "-e",
              "json",
              "-d",
              "projects/aurea"
            ],
            "port": 6006
          }
        },
        "build-storybook": {
          "builder": "@storybook/angular:build-storybook",
          "options": {
            "configDir": "projects/aurea/.storybook",
            "browserTarget": "aurea:build",
            "compodoc": true,
            "compodocArgs": [
              "-e",
              "json",
              "-d",
              "projects/aurea"
            ],
            "outputDir": "storybook-static"
          }
        }
      }
    }
  }
}
