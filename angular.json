{
  "$schema": "./node_modules/@angular/cli/lib/config/schema.json",
  "version": 1,
  "cli": {
    "packageManager": "bun",
    "analytics": "67041da8-5eec-4fa8-9270-34cccb9fcfdd",
    "schematicCollections": ["angular-eslint"]
  },
  "newProjectRoot": "projects",
  "projects": {
    "components": {
      "projectType": "library",
      "root": "projects/components",
      "sourceRoot": "projects/components/src",
      "prefix": "au",
      "architect": {
        "build": {
          "builder": "@angular/build:ng-packagr",
          "configurations": {
            "production": {
              "tsConfig": "projects/components/tsconfig.lib.prod.json"
            },
            "development": {
              "tsConfig": "projects/components/tsconfig.lib.json"
            }
          },
          "defaultConfiguration": "production"
        },
        "test": {
          "builder": "@angular/build:unit-test",
          "options": {
            "tsConfig": "projects/components/tsconfig.spec.json",
            "providersFile": "projects/components/src/test-providers.ts"
          },
          "configurations": {
            "coverage": {
              "coverage": true,
              "coverageReporters": ["text", "text-summary", "html", "json-summary"],
              "coverageInclude": ["projects/components/src/lib/**/*.ts"],
              "coverageExclude": [
                "projects/components/src/lib/**/*.stories.ts",
                "projects/components/src/lib/**/*.stories-chrome.ts",
                "projects/components/src/lib/**/*-story-host.ts",
                "projects/components/src/lib/**/form-field.spec-hosts.ts",
                "projects/components/src/lib/**/index.ts",
                "projects/components/src/lib/au-size.ts",
                "projects/components/src/lib/field-option.ts",
                "projects/components/src/lib/table/table-types.ts",
                "projects/components/src/lib/story-docs/story-overview-types.ts"
              ],
              "coverageThresholds": {
                "statements": 100,
                "branches": 100,
                "functions": 100,
                "lines": 100
              }
            }
          }
        },
        "storybook": {
          "builder": "@storybook/angular:start-storybook",
          "options": {
            "configDir": "projects/components/.storybook",
            "browserTarget": "components:build",
            "compodoc": true,
            "compodocArgs": ["-e", "json", "-d", "projects/components"],
            "port": 6006
          }
        },
        "build-storybook": {
          "builder": "@storybook/angular:build-storybook",
          "options": {
            "configDir": "projects/components/.storybook",
            "browserTarget": "components:build",
            "compodoc": true,
            "compodocArgs": ["-e", "json", "-d", "projects/components"],
            "outputDir": "storybook-static"
          }
        },
        "lint": {
          "builder": "@angular-eslint/builder:lint",
          "options": {
            "lintFilePatterns": ["projects/components/**/*.ts", "projects/components/**/*.html"],
            "eslintConfig": "projects/components/eslint.config.js"
          }
        }
      }
    },
    "docs": {
      "projectType": "application",
      "schematics": {
        "@schematics/angular:class": {
          "skipTests": true
        },
        "@schematics/angular:component": {
          "skipTests": true
        },
        "@schematics/angular:directive": {
          "skipTests": true
        },
        "@schematics/angular:guard": {
          "skipTests": true
        },
        "@schematics/angular:interceptor": {
          "skipTests": true
        },
        "@schematics/angular:pipe": {
          "skipTests": true
        },
        "@schematics/angular:resolver": {
          "skipTests": true
        },
        "@schematics/angular:service": {
          "skipTests": true
        }
      },
      "root": "projects/docs",
      "sourceRoot": "projects/docs/src",
      "prefix": "docs",
      "architect": {
        "build": {
          "builder": "@angular/build:application",
          "options": {
            "browser": "projects/docs/src/main.ts",
            "tsConfig": "projects/docs/tsconfig.app.json",
            "assets": [
              {
                "glob": "**/*",
                "input": "projects/docs/public"
              }
            ],
            "styles": ["projects/docs/src/styles.css"]
          },
          "configurations": {
            "production": {
              "budgets": [
                {
                  "type": "initial",
                  "maximumWarning": "800kB",
                  "maximumError": "1.5MB"
                },
                {
                  "type": "anyComponentStyle",
                  "maximumWarning": "32kB",
                  "maximumError": "48kB"
                },
                {
                  "type": "any",
                  "maximumWarning": "800kB",
                  "maximumError": "1.5MB"
                }
              ],
              "outputHashing": "all"
            },
            "development": {
              "optimization": false,
              "extractLicenses": false,
              "sourceMap": true
            }
          },
          "defaultConfiguration": "production"
        },
        "serve": {
          "builder": "@angular/build:dev-server",
          "configurations": {
            "production": {
              "buildTarget": "docs:build:production"
            },
            "development": {
              "buildTarget": "docs:build:development"
            }
          },
          "defaultConfiguration": "development"
        },
        "lint": {
          "builder": "@angular-eslint/builder:lint",
          "options": {
            "lintFilePatterns": ["projects/docs/**/*.ts", "projects/docs/**/*.html"],
            "eslintConfig": "projects/docs/eslint.config.js"
          }
        }
      }
    }
  }
}
