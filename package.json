{
  "name": "aurea",
  "version": "0.0.0",
  "scripts": {
    "ng": "ng",
    "start": "bun run docs",
    "docs": "ng serve docs --port 4200",
    "build:docs": "node scripts/generate-docs-sitemap.mjs && ng build docs",
    "build": "bun run build:components",
    "build:components": "node projects/components/scripts/bundle-aurea-global.mjs && ng build components && node scripts/build-schematics.mjs && node scripts/strip-sourcemaps.mjs",
    "pack:package": "ng build components && npm pack --prefix dist/components --pack-destination=.",
    "watch": "ng build components --watch --configuration development",
    "test": "ng test components --no-watch",
    "test:coverage": "ng test components --no-watch --configuration=coverage",
    "sync:story-overviews": "node projects/components/scripts/generate-story-overview-source.mjs",
    "sync:aurea-global-css": "node projects/components/scripts/bundle-aurea-global.mjs",
    "maintain:storybook": "bun run sync:aurea-global-css && bun run sync:story-overviews && bun run verify:story-tags && bun run verify:visual-manifest",
    "storybook": "ng run components:storybook",
    "build-storybook": "ng run components:build-storybook",
    "test-storybook": "test-storybook --config-dir projects/components/.storybook --url http://127.0.0.1:6006",
    "test-storybook:ci": "bun run build-storybook && start-server-and-test 'bunx http-server storybook-static -a 127.0.0.1 -p 6010 -s' http://127.0.0.1:6010 'test-storybook --config-dir projects/components/.storybook --url http://127.0.0.1:6010'",
    "test:visual": "playwright test -c playwright.visual.config.ts",
    "test:visual:ci": "bun run build-storybook && playwright test -c playwright.visual.config.ts",
    "test:visual:update": "bun run build-storybook && playwright test -c playwright.visual.config.ts --update-snapshots",
    "sync:visual-stories": "node scripts/sync-visual-stories.mjs",
    "verify:visual-manifest": "node scripts/sync-visual-stories.mjs && git diff --exit-code projects/components/e2e-visual/visual-story-manifest.ts",
    "audit:spec-quality": "node scripts/audit-spec-quality.mjs",
    "check:bundle": "node scripts/check-bundle-size.mjs",
    "update:bundle-baseline": "node scripts/update-bundle-baseline.mjs",
    "verify:story-tags": "node scripts/verify-story-tags.mjs",
    "verify:i18n": "node scripts/verify-i18n-parity.mjs",
    "test:docs:e2e": "playwright test -c playwright.docs.config.ts",
    "test:schematics": "node scripts/build-schematics.mjs && node scripts/test-schematics.cjs",
    "ci": "bun scripts/ci-local.mjs",
    "ci:full": "bun scripts/ci-local.mjs --install",
    "ci:fast": "bun scripts/ci-local.mjs --skip-e2e",
    "audit:ci": "node scripts/audit-ci.mjs",
    "validate:tokens": "node scripts/validate-design-tokens.mjs",
    "export:tokens": "node scripts/export-design-tokens.mjs",
    "tag:stories": "node scripts/tag-story-maturity.mjs",
    "lint": "ng lint",
    "format": "prettier --cache --write .",
    "format:check": "prettier --cache --check ."
  },
  "private": true,
  "packageManager": "bun@1.3.11",
  "dependencies": {
    "@angular/common": "^22.0.1",
    "@angular/compiler": "^22.0.1",
    "@angular/core": "^22.0.1",
    "@angular/forms": "^22.0.1",
    "@angular/platform-browser": "^22.0.1",
    "@angular/router": "^22.0.1",
    "rxjs": "~7.8.2",
    "tslib": "^2.8.1"
  },
  "devDependencies": {
    "@angular-devkit/architect": "^0.2200.5",
    "@angular-devkit/core": "^22.0.1",
    "@angular-eslint/builder": "22.0.0",
    "@angular/build": "^22.0.1",
    "@angular/cli": "^22.0.1",
    "@angular/compiler-cli": "^22.0.1",
    "@angular/platform-browser-dynamic": "^22.0.1",
    "@compodoc/compodoc": "^1.2.1",
    "@eslint/js": "^10.0.1",
    "@playwright/test": "1.61.0",
    "@storybook/addon-a11y": "^10.4.6",
    "@storybook/addon-docs": "^10.4.6",
    "@storybook/addon-onboarding": "^10.4.6",
    "@storybook/addon-vitest": "^10.4.6",
    "@storybook/angular": "^10.4.6",
    "@storybook/test-runner": "0.24.4",
    "@testing-library/angular": "^19.4.1",
    "@types/prismjs": "^1.26.6",
    "@vitest/browser-playwright": "^4.1.9",
    "@vitest/coverage-v8": "^4.1.9",
    "ajv": "^8.20.0",
    "angular-eslint": "^22.0.0",
    "axe-playwright": "^2.2.2",
    "eslint": "^10.5.0",
    "eslint-config-prettier": "^10.1.8",
    "globals": "^17.6.0",
    "jsdom": "^29.1.1",
    "ng-packagr": "^22.0.0",
    "playwright": "^1.61.0",
    "prettier": "^3.8.4",
    "prismjs": "^1.30.0",
    "start-server-and-test": "^3.0.11",
    "storybook": "^10.4.6",
    "typescript": "~6.0.3",
    "typescript-eslint": "^8.61.1",
    "vitest": "^4.1.9"
  }
}
