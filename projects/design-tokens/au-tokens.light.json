{
  "$schema": "https://design-tokens.org/schemas/2025-10/format.json",
  "color": {
    "surface": {
      "canvas": { "$value": "#dcdce1", "$type": "color" },
      "raised": { "$value": "#ffffff", "$type": "color" },
      "elevated": { "$value": "#f5f5f7", "$type": "color" },
      "sunken": { "$value": "#d1d1d6", "$type": "color" },
      "inverted": { "$value": "#1d1d1f", "$type": "color" }
    },
    "text": {
      "primary": { "$value": "#1d1d1f", "$type": "color" },
      "secondary": { "$value": "#5a5a60", "$type": "color" },
      "tertiary": { "$value": "#6e6e73", "$type": "color" },
      "on-solid": { "$value": "#ffffff", "$type": "color" }
    },
    "border": {
      "subtle": { "$value": "#c7c7cc", "$type": "color" },
      "default": { "$value": "#aeaeb2", "$type": "color" },
      "strong": { "$value": "#6e6e73", "$type": "color" }
    },
    "action": {
      "primary": { "$value": "#1d1d1f", "$type": "color" },
      "primary-hover": { "$value": "#333336", "$type": "color" },
      "primary-pressed": { "$value": "#222226", "$type": "color" }
    },
    "semantic": {
      "error": { "$value": "#b42318", "$type": "color" },
      "success": { "$value": "#6e6e73", "$type": "color" },
      "warning": { "$value": "#6e6e73", "$type": "color" },
      "info": { "$value": "#6e6e73", "$type": "color" }
    },
    "focus": {
      "ring": { "$value": "#1d1d1f", "$type": "color" }
    }
  },
  "fontFamily": {
    "sans": {
      "$value": ["Onest", "ui-sans-serif", "system-ui", "sans-serif"],
      "$type": "fontFamily"
    },
    "mono": {
      "$value": ["JetBrains Mono", "ui-monospace", "monospace"],
      "$type": "fontFamily"
    }
  },
  "fontSize": {
    "xs": { "$value": "0.75rem", "$type": "dimension" },
    "sm": { "$value": "0.875rem", "$type": "dimension" },
    "md": { "$value": "1rem", "$type": "dimension" },
    "lg": { "$value": "1.125rem", "$type": "dimension" },
    "xl": { "$value": "1.25rem", "$type": "dimension" }
  },
  "spacing": {
    "1": { "$value": "0.25rem", "$type": "dimension" },
    "2": { "$value": "0.5rem", "$type": "dimension" },
    "3": { "$value": "0.75rem", "$type": "dimension" },
    "4": { "$value": "1rem", "$type": "dimension" },
    "6": { "$value": "1.5rem", "$type": "dimension" },
    "8": { "$value": "2rem", "$type": "dimension" }
  },
  "borderRadius": {
    "sm": { "$value": "0.5rem", "$type": "dimension" },
    "md": { "$value": "0.625rem", "$type": "dimension" },
    "lg": { "$value": "0.75rem", "$type": "dimension" },
    "field": { "$value": "0.375rem", "$type": "dimension" },
    "pill": { "$value": "9999px", "$type": "dimension" }
  }
}
