{
  "$schema": "https://design-tokens.org/schemas/2025-10/format.json",
  "color": {
    "surface": {
      "canvas": { "$value": "#f1f2f4", "$type": "color" },
      "raised": { "$value": "#ffffff", "$type": "color" },
      "elevated": { "$value": "#f8f9fa", "$type": "color" },
      "sunken": { "$value": "#e9ebef", "$type": "color" },
      "inverted": { "$value": "#101418", "$type": "color" }
    },
    "text": {
      "primary": { "$value": "#101418", "$type": "color" },
      "secondary": { "$value": "#3d4a5c", "$type": "color" },
      "tertiary": { "$value": "#5c6b7d", "$type": "color" },
      "on-solid": { "$value": "#ffffff", "$type": "color" }
    },
    "border": {
      "subtle": { "$value": "#e0e4ea", "$type": "color" },
      "default": { "$value": "#c8ced7", "$type": "color" },
      "strong": { "$value": "#8d98a6", "$type": "color" }
    },
    "action": {
      "primary": { "$value": "#1059c8", "$type": "color" },
      "primary-hover": { "$value": "#0d4aa3", "$type": "color" },
      "primary-pressed": { "$value": "#0a3a85", "$type": "color" }
    },
    "semantic": {
      "error": { "$value": "#b42318", "$type": "color" },
      "success": { "$value": "#047857", "$type": "color" },
      "warning": { "$value": "#b45309", "$type": "color" },
      "info": { "$value": "#0369a1", "$type": "color" }
    },
    "focus": {
      "ring": { "$value": "#1059c8", "$type": "color" }
    }
  },
  "fontFamily": {
    "sans": {
      "$value": ["Onest", "ui-sans-serif", "system-ui", "sans-serif"],
      "$type": "fontFamily"
    },
    "mono": {
      "$value": ["JetBrains Mono", "ui-monospace", "monospace"],
      "$type": "fontFamily"
    }
  },
  "fontSize": {
    "xs": { "$value": "0.75rem", "$type": "dimension" },
    "sm": { "$value": "0.875rem", "$type": "dimension" },
    "md": { "$value": "1rem", "$type": "dimension" },
    "lg": { "$value": "1.125rem", "$type": "dimension" },
    "xl": { "$value": "1.25rem", "$type": "dimension" }
  },
  "spacing": {
    "1": { "$value": "0.25rem", "$type": "dimension" },
    "2": { "$value": "0.5rem", "$type": "dimension" },
    "3": { "$value": "0.75rem", "$type": "dimension" },
    "4": { "$value": "1rem", "$type": "dimension" },
    "6": { "$value": "1.5rem", "$type": "dimension" },
    "8": { "$value": "2rem", "$type": "dimension" }
  },
  "borderRadius": {
    "sm": { "$value": "0.25rem", "$type": "dimension" },
    "md": { "$value": "0.375rem", "$type": "dimension" },
    "lg": { "$value": "0.5rem", "$type": "dimension" },
    "field": { "$value": "0.125rem", "$type": "dimension" },
    "pill": { "$value": "9999px", "$type": "dimension" }
  }
}
