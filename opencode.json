{
  "$schema": "https://opencode.ai/config.json",
  "mcp": {
    "angular-cli": {
      "command": ["npx", "-y", "@angular/cli", "mcp"],
      "type": "local",
      "enabled": true
    },
    "context7": {
      "enabled": true,
      "type": "remote",
      "url": "https://mcp.context7.com/mcp"
    },
    "engram": {
      "command": ["/home/tonicarreras/.local/bin/engram", "mcp", "--tools=agent"],
      "type": "local",
      "environment": {
        "ENGRAM_PROJECT": "aurea-ds"
      }
    }
  },
  "skills": {
    "path": ".agents/skills"
  }
}
